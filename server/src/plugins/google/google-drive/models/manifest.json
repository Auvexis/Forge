{
  "name": "Google Drive",
  "id": "google-drive",
  "description": "Allows the AI to interact with Google Drive to manage files and folders.",
  "methods": {
    "listFiles": {
      "description": "List files/folders in a folder or root directory.",
      "parameters": {
        "pageSize": { "type": "number", "required": false },
        "query": { "type": "string", "required": false }
      },
      "queryGuide": {
        "description": "Guide for building Google Drive queries.",
        "operators": ["=", "!=", "contains", "not", "and", "or", ">", "<"],
        "fields": [
          "name",
          "mimeType",
          "fullText",
          "modifiedTime",
          "starred",
          "trashed",
          "parents",
          "owners",
          "writers",
          "sharedWithMe",
          "properties",
          "appProperties",
          "visibility"
        ]
      },
      "queryExamples": [
        {
          "description": "Files with exact name",
          "query": "name = 'hello'"
        },
        {
          "description": "Files containing words",
          "query": "name contains 'hello' and name contains 'goodbye'"
        },
        {
          "description": "Exclude word in name",
          "query": "not name contains 'hello'"
        },
        {
          "description": "Search in file content",
          "query": "fullText contains 'important'"
        },
        {
          "description": "Exact phrase",
          "query": "fullText contains '\"hello world\"'"
        },
        {
          "description": "Folders only",
          "query": "mimeType = 'application/vnd.google-apps.folder'"
        },
        {
          "description": "Not folders",
          "query": "mimeType != 'application/vnd.google-apps.folder'"
        },
        {
          "description": "PDF files only (excluding folders)",
          "query": "mimeType!='application/vnd.google-apps.folder' and name contains '.pdf'"
        },
        {
          "description": "Modified after date",
          "query": "modifiedTime > '2012-06-04T12:00:00'"
        },
        {
          "description": "Images or videos after date",
          "query": "modifiedTime > '2012-06-04T12:00:00' and (mimeType contains 'image/' or mimeType contains 'video/')"
        },
        {
          "description": "Starred files",
          "query": "starred = true"
        },
        {
          "description": "Inside folder",
          "query": "'1234567' in parents"
        },
        {
          "description": "Owned by user",
          "query": "'test@example.org' in owners"
        },
        {
          "description": "Shared with me and filtered",
          "query": "sharedWithMe and name contains 'hello'"
        },
        {
          "description": "Custom public property",
          "query": "properties has { key='mass' and value='1.3kg' }"
        },
        {
          "description": "Custom app property",
          "query": "appProperties has { key='additionalID' and value='8e8aceg2af2ge72e78' }"
        },
        {
          "description": "Private files only",
          "query": "visibility = 'limited'"
        }
      ],
      "responseExample": {
        "data": [
          {
            "parents": ["11INSeUlIgOKmNhX9nu3K3AJpPJDnqrvE"],
            "id": "1BfBaUiezI88H7nk9TB6Ymk2fdrK8Nz8I",
            "name": "cv.pdf",
            "mimeType": "application/pdf",
            "trashed": true,
            "modifiedTime": "2026-03-01T14:39:07.000Z",
            "size": "114009"
          },
          {
            "parents": ["1z5VVWLRvv3rShptNRjXlu3ARWRWPrane"],
            "id": "1AlyWKxw6mCcUKrus7J1yKe0DqnfztpyZ",
            "name": "projects",
            "mimeType": "application/vnd.google-apps.folder",
            "trashed": false,
            "modifiedTime": "2026-03-01T14:38:39.000Z",
            "size": "115830"
          }
        ]
      }
    },
